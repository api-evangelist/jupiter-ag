          "name": "Build a swap transaction",
          "request": {
            "name": "Build a swap transaction",
            "description": {
              "content": "Converts a quote response and a user public key into a serialized Solana transaction ready to be signed and submitted.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "swap"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quoteResponse\": {\n    \"inputMint\": \"<string>\",\n    \"inAmount\": \"<string>\",\n    \"outputMint\": \"<string>\",\n    \"outAmount\": \"<string>\",\n    \"otherAmountThreshold\": \"<string>\",\n    \"swapMode\": \"<string>\",\n    \"slippageBps\": \"<integer>\",\n    \"priceImpactPct\": \"<string>\",\n    \"routePlan\": [\n      \"<object>\",\n      \"<object>\"\n    ]\n  },\n  \"userPublicKey\": \"<string>\",\n  \"dynamicComputeUnitLimit\": \"<boolean>\",\n  \"dynamicSlippage\": \"<boolean>\",\n  \"prioritizationFeeLamports\": \"<integer>\"\n}",
              "options": {
