{
  "item": [
    {
      "id": "b6617275-8860-44c0-bf19-e8b8a37c0a7f",
      "name": "Swap",
      "description": {
        "content": "Quote and build Solana DEX-aggregator swap transactions.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "531d300b-54b8-4c93-959d-80a6d64cbd72",
          "name": "Get a swap quote",
          "request": {
            "name": "Get a swap quote",
            "description": {
              "content": "Returns the best routing plan and pricing for swapping an input token into an output token across Solana DEXes. The response is passed directly to /swap to build a swap transaction.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "quote"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "inputMint",
                  "value": "<string>",
                  "description": "(Required) The input token mint address."
                },
                {
                  "disabled": false,
                  "key": "outputMint",
                  "value": "<string>",
                  "description": "(Required) The output token mint address."
                },
                {
                  "disabled": false,
                  "key": "amount",
                  "value": "<long>",
                  "description": "(Required) Raw input token amount in atomic units (lamports for SOL)."
                },
                {
                  "disabled": false,
                  "key": "slippageBps",
                  "value": "<integer>",
                  "description": "Acceptable slippage in basis points (100 bps = 1%)."
                },
                {
                  "disabled": false,
                  "key": "swapMode",
                  "value": "<string>",
                  "description": "Whether the amount represents the exact input or exact output."
                },
                {
                  "disabled": false,
                  "key": "restrictIntermediateTokens",
                  "value": "<boolean>",
                  "description": "When true, restricts intermediate tokens to a curated stable set for more reliable routes."
                },
                {
                  "disabled": false,
                  "key": "onlyDirectRoutes",
                  "value": "<boolean>",
                  "description": "Restricts routing to single-market direct swaps only."
                },
                {
                  "disabled": false,
                  "key": "asLegacyTransaction",
                  "value": "<boolean>",
                  "description": "Returns a legacy (non-versioned) transaction when used with /swap."
                },
                {
                  "disabled": false,
                  "key": "maxAccounts",
                  "value": "<integer>",
                  "description": "Upper bound on the accounts used in the swap transaction."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
          "response": [
            {
              "id": "f176be50-259e-42b0-ada7-38f5d3d3e99f",
              "name": "A routing plan and quote ready to be passed to /swap.",
              "originalRequest": {
                "url": {
                  "path": [
                    "quote"
                  ],
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "query": [
                    {
                      "key": "inputMint",
                      "value": "<string>"
                    },
                    {
                      "key": "outputMint",
                      "value": "<string>"
                    },
                    {
                      "key": "amount",
                      "value": "<long>"
                    },
                    {
                      "key": "slippageBps",
                      "value": "<integer>"
                    },
                    {
                      "key": "swapMode",
                      "value": "<string>"
                    },
                    {
                      "key": "restrictIntermediateTokens",
                      "value": "<boolean>"
                    },
                    {
                      "key": "onlyDirectRoutes",
                      "value": "<boolean>"
                    },
                    {
                      "key": "asLegacyTransaction",
                      "value": "<boolean>"
                    },
                    {
                      "key": "maxAccounts",
                      "value": "<integer>"
                    }
                  ],
                  "variable": []
                },
                "header": [
                  {
                    "description": {
                      "content": "Added as a part of security scheme: apikey",
                      "type": "text/plain"
                    },
                    "key": "x-api-key",
                    "value": "<API Key>"
                  },
                  {
                    "key": "Accept",
                    "value": "application/json"
                  }
                ],
                "method": "GET",
                "body": {}
              },
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"inputMint\": \"string\",\n  \"inAmount\": \"string\",\n  \"outputMint\": \"string\",\n  \"outAmount\": \"string\",\n  \"otherAmountThreshold\": \"string\",\n  \"swapMode\": \"string\",\n  \"slippageBps\": 8727,\n  \"priceImpactPct\": \"string\"\n}",
              "cookie": [],
              "_postman_previewlanguage": "json"
            }
          ],
          "event": [],
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          }
        },
        {
