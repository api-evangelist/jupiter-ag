  "info": {
    "_postman_id": "78688f09-a581-4e4a-b629-7806fca89f7b",
    "name": "Jupiter Swap API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Jupiter is the leading Solana DEX aggregator. The Swap API returns the best routes across Solana DEXes and builds serialized transactions ready to be signed and sent. The full-rate production endpoint is api.jup.ag; a rate-limited public endpoint is available at lite-api.jup.ag. Requests against api.jup.ag require an API key issued via the Jupiter Developer Platform.\n\nContact Support:\n Name: Jupiter Developer Platform",
      "type": "text/plain"
    }
  }
